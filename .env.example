# --- Database ---
# PostgreSQL connection string (e.g. Neon / Supabase / local)
DATABASE_URL="postgresql://user:password@localhost:5432/saas?schema=public"

# --- Auth.js (NextAuth) ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# The Price ID of your single subscription plan (test mode)
NEXT_PUBLIC_STRIPE_PRICE_ID="price_..."
